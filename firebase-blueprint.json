{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "companyName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role", "createdAt"]
    },
    "Quote": {
      "title": "Campaign Quote",
      "description": "Marketing campaign quote with AI-generated analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "companyName": { "type": "string" },
        "campaignName": { "type": "string" },
        "objective": { "type": "string", "enum": ["Awareness", "Conversion", "Engagement", "Retention", "Rebrand"] },
        "deliverables": { "type": "string" },
        "budgetEstimate": { "type": "number" },
        "duration": { "type": "string" },
        "targetAudience": { "type": "string" },
        "aiAnalysis": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "campaignName", "objective", "budgetEstimate", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile information."
    },
    "/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "Collection of all financial quotes across the system."
    }
  }
}
