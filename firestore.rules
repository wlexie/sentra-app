rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens don't contain roles yet, so we get them from the DB
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100 &&
             data.role in ['admin', 'client'];
    }

    function isValidQuote(data) {
      return data.clientId is string && data.clientId.size() <= 128 &&
             data.clientName is string && data.clientName.size() <= 200 &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.campaignName is string && data.campaignName.size() <= 200 &&
             data.objective in ['Awareness', 'Conversion', 'Engagement', 'Retention', 'Rebrand'] &&
             data.budgetEstimate is number && data.budgetEstimate >= 0 &&
             data.status in ['pending', 'approved', 'rejected', 'modifying'] &&
             data.duration is string && data.duration.size() <= 100 &&
             data.deliverables is string && data.deliverables.size() <= 5000 &&
             data.targetAudience is string && data.targetAudience.size() <= 5000 &&
             (!('aiAnalysis' in data) || (data.aiAnalysis is string && data.aiAnalysis.size() <= 20000));
    }

    // 1. The "Master Gate" (Collections)
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
                    && isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().role == 'client'; // Forced client status on self-reg
      
      allow update: if isSignedIn() && (
        // Client can update their own info (but not role)
        (isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'companyName']))
        || 
        // Admins can update anything
        (isAdmin() && isValidUser(incoming()))
      );
    }

    match /quotes/{quoteId} {
      allow get: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      
      allow create: if isSignedIn() 
                    && isValidQuote(incoming())
                    && (isAdmin() || incoming().clientId == request.auth.uid);

      allow update: if isSignedIn() && (
        isAdmin() // Admins can change everything including status
        || 
        // Clients can change pending content but NOT status
        (existing().clientId == request.auth.uid && 
         existing().status == 'pending' &&
         isValidQuote(incoming()) &&
         incoming().status == existing().status &&
         incoming().diff(existing()).affectedKeys().hasOnly(['campaignName', 'objective', 'deliverables', 'budgetEstimate', 'duration', 'targetAudience']))
      );
      
      allow delete: if isAdmin(); // Only admins can delete quotes
    }
  }
}
